 #include "windowing/WinSystem.h"
 #include "windowing/linux/WinSystemEGL.h"
 
+#include <cctype>
+#include <cstdlib>
+#include <fstream>
 #include <memory>
+#include <string>
 
 using namespace KODI::UTILS::EGL;
 
+
+namespace
+{
+bool MiniLoongDeviceFileMatches()
+{
+  std::ifstream deviceFile("/home/ark/.config/.DEVICE");
+  std::string device;
+  if (!deviceFile || !std::getline(deviceFile, device))
+    return false;
+
+  for (auto& c : device)
+    c = static_cast<char>(std::tolower(static_cast<unsigned char>(c)));
+
+  return device.find("miniloong") != std::string::npos;
+}
+
+bool OutputNameIsHDMI(std::string output)
+{
+  for (auto& c : output)
+    c = static_cast<char>(std::tolower(static_cast<unsigned char>(c)));
+
+  return output.find("hdmi") != std::string::npos;
+}
+
+bool MiniLoongHDMIConnected()
+{
+  auto winSystem = CServiceBroker::GetWinSystem();
+  if (!winSystem)
+    return false;
+
+  for (const auto& output : winSystem->GetConnectedOutputs())
+  {
+    if (OutputNameIsHDMI(output))
+      return true;
+  }
+
+  return false;
+}
+
+bool IsMiniLoongInternalDisplayRotationEnabled()
+{
+  if (const char* env = std::getenv("KODI_MINILOONG_ROTATE"))
+  {
+    std::string value(env);
+    for (auto& c : value)
+      c = static_cast<char>(std::tolower(static_cast<unsigned char>(c)));
+
+    if (value == "0" || value == "false" || value == "no" || value == "off")
+      return false;
+  }
+
+  if (!MiniLoongDeviceFileMatches())
+    return false;
+
+  if (MiniLoongHDMIConnected())
+    return false;
+
+  return true;
+}
+}
